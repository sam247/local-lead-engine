# Optional: GA4 measurement ID for analytics (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=

# Lead capture (Resend)
# RESEND_API_KEY=

# Optional: override lead notification recipient (e.g. your email for testing).
# If set, all lead emails are sent here instead of the vertical default.
# LEAD_EMAIL_OVERRIDE=sampettiford@googlemail.com

# Google Sheets logging (Service Account)
# GOOGLE_SHEETS_SHEET_ID=1SHXw2gYxS82queHl9yi_bCQGlK-pO6w84EhJYos7qBM
# GOOGLE_SHEETS_CLIENT_EMAIL=
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEETS_WEBHOOK_URL=https://hooks.zapier.com/...

# Public Twilio inbound (E.164). Site UI, tel: links, JSON-LD, and Sheet `to_number` on call clicks.
# Must match the Twilio number configured for this site.
# NEXT_PUBLIC_PHONE_NUMBER=+44XXXXXXXXXX

# Server-only: staff mobile/desk Twilio <Dial> forwards to; never shown on site.
# FORWARD_PHONE_NUMBER=+44XXXXXXXXXX

# Groundworks Twilio status → GA4 Measurement Protocol (optional; default off)
# TWILIO_GA4_ENABLED=true
# Requires GA4_MEASUREMENT_ID and GA4_API_SECRET when enabled.

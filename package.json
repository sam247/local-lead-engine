{
  "name": "local-lead-engine",
  "private": true,
  "workspaces": [
    "engine",
    "verticals/drains",
    "verticals/surveys",
    "verticals/access",
    "verticals/groundworks"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=verticals-drains",
    "build": "npm run build --workspace=verticals-drains",
    "start": "npm run start --workspace=verticals-drains",
    "blog:image-manifest": "node scripts/blog-image-manifest.mjs",
    "blog:place-images": "node scripts/blog-image-manifest.mjs | node scripts/blog-place-images.mjs --source=./assets",
    "project:image-manifest": "node scripts/project-image-manifest.mjs",
    "project:place-images": "node scripts/project-place-images.mjs --source=./assets --manifest=project-manifest.json"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
